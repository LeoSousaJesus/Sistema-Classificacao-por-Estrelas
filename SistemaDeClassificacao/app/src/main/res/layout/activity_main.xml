<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- TextView: "Avalie o jogo abaixo:" -->
    <TextView
        android:id="@+id/txtAvalieOJogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/avalie_o_jogo_abaixo"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_alignParentTop="true" />

    <!-- LinearLayout Horizontal: layoutFoto -->
    <LinearLayout
        android:id="@+id/layoutFoto"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_below="@+id/txtAvalieOJogo"
        android:layout_marginTop="12dp"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true">

        <!-- ImageView: imagem_jogo -->
        <ImageView
            android:id="@+id/imagemJogo"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:src="@drawable/jogo_angry_birds"
            android:contentDescription="@string/nome_jogo"
            android:scaleType="centerCrop" />

    </LinearLayout>

    <!-- TextView: "Deixe seu voto:" -->
    <TextView
        android:id="@+id/txtDeixeSeuVoto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/deixe_seu_voto"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_below="@+id/layoutFoto"
        android:layout_marginTop="12dp" />

    <!-- RatingBar: rtbvotacao -->
    <RatingBar
        android:id="@+id/rtbvotacao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="1"
        android:rating="0"
        android:layout_below="@+id/txtDeixeSeuVoto"
        android:layout_marginTop="6dp"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true" />

    <!-- TextView: txtstatus -->
    <TextView
        android:id="@+id/txtstatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_label"
        android:textSize="14sp"
        android:textColor="@color/status_ruim"
        android:layout_below="@+id/rtbvotacao"
        android:layout_marginTop="12dp"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true" />

</RelativeLayout>
